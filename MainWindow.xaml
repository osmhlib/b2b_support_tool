<Window x:Class="b2b_support_tool.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:b2b_support_tool"
        mc:Ignorable="d"
        Title="{Binding WindowTitle}" Height="450" Width="500"
        ResizeMode="CanMinimize">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Width" Value="140"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,0,0,0"/>
        </Style>
        <Style x:Key="IconButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="24"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Padding" Value="4"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBackground"
                                Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True"
                                              SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBackground" Property="Background" Value="#DDE8F5"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBackground" Property="Background" Value="#BFD1E6"/>
                                <Setter Property="Opacity" Value="0.75"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.35"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="150" />
        </Grid.RowDefinitions>

        <TabControl Grid.Row="0">
            <TabItem Header="Clean">
                <Grid Background="#FFE5E5E5">
                    <CheckBox x:Name="delCheck" Content="Delete check files older than 14 days"
                              HorizontalAlignment="Left" Margin="20,30,0,0" VerticalAlignment="Top"/>
                    <CheckBox x:Name="delLog" Content="Delete logs older than 14 days"
                              HorizontalAlignment="Left" Margin="20,70,0,0" VerticalAlignment="Top"/>
                    <CheckBox x:Name="delTemp" Content="Clear the TEMP folder"
                              HorizontalAlignment="Left" Margin="20,110,0,0" VerticalAlignment="Top"/>
                    <CheckBox x:Name="delRecyclebin" Content="Clean the recyclebin folder"
                              HorizontalAlignment="Left" Margin="20,150,0,0" VerticalAlignment="Top"/>
                    <Button x:Name="clean" Content="START"
                            HorizontalAlignment="Left" Margin="300,30,0,0" VerticalAlignment="Top"/>
                </Grid>
            </TabItem>
            <TabItem Header="Ping">
                <Grid Background="#FFE5E5E5">
                    <CheckBox x:Name="pingFtp" Content="Ping FTP"
                              HorizontalAlignment="Left" Margin="20,30,0,0" VerticalAlignment="Top"/>
                    <CheckBox x:Name="traceFtp" Content="Trace FTP"
                              HorizontalAlignment="Left" Margin="20,70,0,0" VerticalAlignment="Top"/>
                    <CheckBox x:Name="pingCrm" Content="Ping CRM"
                              HorizontalAlignment="Left" Margin="20,110,0,0" VerticalAlignment="Top"/>
                    <CheckBox x:Name="traceCrm" Content="Trace CRM"
                              HorizontalAlignment="Left" Margin="20,150,0,0" VerticalAlignment="Top"/>
                    <Button x:Name="netTest" Content="START"
                            HorizontalAlignment="Left" Margin="300,30,0,0" VerticalAlignment="Top"/>
                    <TextBox x:Name="externalIpBox"
                             HorizontalAlignment="Left" Margin="20,205,0,0"
                             VerticalAlignment="Top" Width="90" Height="20.4"
                             Text="Waiting..."
                             IsReadOnly="True"
                             TextChanged="ExternalIpBox_TextChanged"/>
                    <TextBlock HorizontalAlignment="Left" Margin="20,184,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Height="16"><Run Text="External IP"/><Run Language="uk-ua" Text=":"/><LineBreak/><Run Language="uk-ua"/></TextBlock>
                    <Button x:Name="copyExternalIp"
                            Style="{StaticResource IconButtonStyle}"
                            HorizontalAlignment="Left" Margin="115,203,0,0"
                            VerticalAlignment="Top"
                            ToolTip="Copy IP">
                        <Grid Width="14" Height="14">
                            <Path Fill="#333333" Stretch="Uniform" Data="M5,2 L14,2 L14,4 L7,4 L7,13 L5,13 Z M8,6 L17,6 L17,18 L8,18 Z M10,8 L10,16 L15,16 L15,8 Z"/>
                        </Grid>
                    </Button>
                    <Button x:Name="refreshExternalIp"
                            Style="{StaticResource IconButtonStyle}"
                            HorizontalAlignment="Left" Margin="144,203,0,0"
                            VerticalAlignment="Top"
                            ToolTip="Refresh IP">
                        <Grid Width="14" Height="14">
                            <Path Fill="#333333" Stretch="Uniform" Data="M16.8,6.2 C15.6,4.8 13.9,4 12,4 C8.1,4 5,7.1 5,11 L3,11 C3,6 7,2 12,2 C14.4,2 16.6,3 18.2,4.8 L20,3 L20,9 L14,9 Z M7.2,15.8 C8.4,17.2 10.1,18 12,18 C15.9,18 19,14.9 19,11 L21,11 C21,16 17,20 12,20 C9.6,20 7.4,19 5.8,17.2 L4,19 L4,13 L10,13 Z"/>
                        </Grid>
                    </Button>
                </Grid>
            </TabItem>
            <TabItem Header="Modules">
                <Grid Background="#FFE5E5E5">
                    <CheckBox x:Name="restartIndicator" Content="Restart ShopdeskIndicator"
                              HorizontalAlignment="Left" Margin="20,30,0,0" VerticalAlignment="Top"/>
                    <CheckBox x:Name="restartBridge" Content="Restart Bridge"
                              HorizontalAlignment="Left" Margin="20,70,0,0" VerticalAlignment="Top"/>
                    <CheckBox x:Name="restartTccLocalProcessor" Content="Restart TccLocalProcessor"
                              HorizontalAlignment="Left" Margin="20,110,0,0" VerticalAlignment="Top"/>
                    <Button x:Name="modulesStart" Content="START"
                            HorizontalAlignment="Left" Margin="300,30,0,0" VerticalAlignment="Top"/>
                </Grid>
            </TabItem>
            <TabItem Header="Update">
                <Grid Background="#FFE5E5E5">
                    <CheckBox x:Name="updateShopdesk" Content="Install or update Shopdesk"
                              HorizontalAlignment="Left" Margin="20,30,0,0" VerticalAlignment="Top"/>
                    <CheckBox x:Name="updateScaleServer" Content="Install or update ScaleServer"
                              HorizontalAlignment="Left" Margin="20,70,0,0" VerticalAlignment="Top"/>
                    <Button x:Name="updateStart" Content="START"
                            HorizontalAlignment="Left" Margin="300,30,0,0" VerticalAlignment="Top"/>
                </Grid>
            </TabItem>
            <TabItem Header="Repair">
                <Grid Background="#FFE5E5E5">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="350">
                        <Button x:Name="sfc" Content="sfc /scannow" Margin="0,10,0,10" Width="200"/>
                        <Button x:Name="dism" Content="/DISM" Margin="0,10,0,10" Width="200"/>
                        <Button x:Name="chkdsk" Content="Checkdisk" Margin="0,10,0,10" Width="200"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem Header="Other">
                <Grid Background="#FFE5E5E5">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="350">
                        <Button x:Name="printRestart" Content="Restart printer service"
                                Margin="0,10,0,10" Width="200"/>
                        <Button x:Name="anydeskIdRenew" Content="Renew AnyDesk ID"
                                Margin="0,10,0,10" Width="200"/>
                        <Button x:Name="regDll" Content="Register weighing libraries"
                                Margin="0,10,0,10" Width="200"/>
                        <Button x:Name="regWIN" Content="Activate Windows"
                                Margin="0,10,0,10" Width="200"/>
                    </StackPanel>
                </Grid>
            </TabItem>
        </TabControl>

        <TextBox x:Name="outputBox"
         Grid.Row="1"
         IsReadOnly="True"
         VerticalScrollBarVisibility="Auto"
         AcceptsReturn="True"
         TextWrapping="Wrap"
         FontFamily="Consolas"
         FontSize="13"
         Background="DarkBlue"
         Foreground="White"/>
    </Grid>
</Window>
